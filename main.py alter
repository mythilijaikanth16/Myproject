# ── Student routes ─────────────────────────────────────────────────────────────
@app.post("/register", response_model=StudentOut, status_code=201)
async def register_student(
    name: str = Form(...),
    student_class: str = Form(...),
    roll_no: str = Form(...),
    file: Optional[UploadFile] = File(None),
    user: str = Depends(current_user),
):
    name, student_class, roll_no = name.strip(), student_class.strip(), roll_no.strip()

    file_url = None
    if file and file.filename:
        file_url = await file_to_base64(file)

    students = load_students()
    student  = {
        "id":            next_id(students),
        "name":          name,
        "student_class": student_class,
        "roll_no":       roll_no,
        "file_url":      file_url,
        "registered_at": datetime.now(timezone.utc).isoformat(),
    }
    students.append(student)
    save_students(students)
    return student

@app.get("/students", response_model=List[StudentOut])
def list_students(user: str = Depends(current_user)):
    return load_students()

@app.get("/students/{student_id}", response_model=StudentOut)
def get_student(student_id: int, user: str = Depends(current_user)):
    return find_student(load_students(), student_id)

@app.put("/students/{student_id}", response_model=StudentOut)
async def update_student(
    student_id: int,
    name: Optional[str] = Form(None),
    student_class: Optional[str] = Form(None),
    roll_no: Optional[str] = Form(None),
    file: Optional[UploadFile] = File(None),
    user: str = Depends(current_user),
):
    students = load_students()
    student  = find_student(students, student_id)

    if name:          student["name"]          = name.strip()
    if student_class: student["student_class"] = student_class.strip()
    if roll_no:       student["roll_no"]        = roll_no.strip()

    if file and file.filename:
        student["file_url"] = await file_to_base64(file)

    save_students(students)
    return student

@app.delete("/students/{student_id}")
def delete_student(student_id: int, user: str = Depends(current_user)):
    students = load_students()
    find_student(students, student_id)
    save_students([s for s in students if s["id"] != student_id])
    return {"message": f"Student {student_id} deleted."}

@app.get("/")
def root():
    return {"status": "Student Registry API v2 is running 🎓"}
