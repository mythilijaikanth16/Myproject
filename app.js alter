function Chatbot({ students }) {

  const [open, setOpen] = useState(false);

  const [msgs, setMsgs] = useState([
    {
      from: 'bot',
      text:
        "👋 Hi! I'm **Regs**, your Student Registry assistant.\nAsk me anything or use the quick buttons below!",
      id: 0,
    },
  ]);

  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);

  const bottomRef = useRef();

  useEffect(() => {
    if (open) {
      bottomRef.current?.scrollIntoView({
        behavior: 'smooth'
      });
    }
  }, [msgs, open]);

  function send(text) {

    const trimmed = (text || input).trim();

    if (!trimmed || loading) return;

    const userMsg = {
      from: 'user',
      text: trimmed,
      id: Date.now(),
    };

    setMsgs(prev => [...prev, userMsg]);

    setInput('');
    setLoading(true);

    setTimeout(() => {

      const reply = botReply(trimmed, students);

      setMsgs(prev => [
        ...prev,
        {
          from: 'bot',
          text: reply,
          id: Date.now() + 1,
        },
      ]);

      setLoading(false);

    }, 600);
  }

  function renderText(text) {

    const parts = text.split(/\*\*(.*?)\*\*/g);

    return parts.map((p, i) =>

      i % 2 === 1
        ? <strong key={i}>{p}</strong>
        : p.split('\n').map((line, j, arr) =>
            j < arr.length - 1
              ? <span key={j}>{line}<br /></span>
              : <span key={j}>{line}</span>
          )
    );
  }

  return (
    <>
      {/* Floating Button */}
      <button
        onClick={() => setOpen(o => !o)}
        style={{
          position: 'fixed',
          bottom: '1.5rem',
          right: '1.5rem',
          width: '54px',
          height: '54px',
          borderRadius: '50%',
          background: 'linear-gradient(135deg, #4f46e5, #7c3aed)',
          color: '#fff',
          border: 'none',
          cursor: 'pointer',
          fontSize: '1.5rem',
          zIndex: 10000,
        }}
      >
        {open ? '✕' : '🤖'}
      </button>

      {/* Chat Window */}
      {open && (
        <div
          style={{
            position: 'fixed',
            bottom: '5.5rem',
            right: '1.5rem',
            width: '340px',
            maxHeight: '520px',
            background: '#fff',
            borderRadius: '16px',
            display: 'flex',
            flexDirection: 'column',
            overflow: 'hidden',
            zIndex: 10000,
            boxShadow: '0 12px 48px rgba(0,0,0,0.18)',
          }}
        >

          {/* Header */}
          <div
            style={{
              background:
                'linear-gradient(135deg, #4f46e5, #7c3aed)',
              color: '#fff',
              padding: '1rem',
              fontWeight: 'bold',
            }}
          >
            🤖 Regs Assistant
          </div>

          {/* Messages */}
          <div
            style={{
              flex: 1,
              overflowY: 'auto',
              padding: '1rem',
              background: '#f9fafb',
            }}
          >

            {msgs.map(m => (
              <div
                key={m.id}
                style={{
                  marginBottom: '0.75rem',
                  textAlign:
                    m.from === 'user'
                      ? 'right'
                      : 'left',
                }}
              >

                <div
                  style={{
                    display: 'inline-block',
                    padding: '0.65rem 0.85rem',
                    borderRadius: '12px',
                    background:
                      m.from === 'user'
                        ? '#4f46e5'
                        : '#fff',
                    color:
                      m.from === 'user'
                        ? '#fff'
                        : '#111',
                    maxWidth: '85%',
                    whiteSpace: 'pre-wrap',
                  }}
                >
                  {m.from === 'bot'
                    ? renderText(m.text)
                    : m.text}
                </div>

              </div>
            ))}

            {loading && (
              <div>🤖 Typing...</div>
            )}

            <div ref={bottomRef} />

          </div>

          {/* Quick Buttons */}
          <div
            style={{
              display: 'flex',
              flexWrap: 'wrap',
              gap: '0.4rem',
              padding: '0.75rem',
              borderTop: '1px solid #eee',
            }}
          >

            {QUICK_PROMPTS.map(q => (
              <button
                key={q.text}
                onClick={() => send(q.text)}
                style={{
                  padding: '4px 10px',
                  borderRadius: '999px',
                  border: '1px solid #ddd',
                  background: '#f3f4f6',
                  cursor: 'pointer',
                  fontSize: '0.75rem',
                }}
              >
                {q.label}
              </button>
            ))}

          </div>

          {/* Input */}
          <div
            style={{
              display: 'flex',
              padding: '0.75rem',
              gap: '0.5rem',
              borderTop: '1px solid #eee',
            }}
          >

            <input
              value={input}
              onChange={e => setInput(e.target.value)}
              onKeyDown={e =>
                e.key === 'Enter' && send()
              }
              placeholder="Ask Regs anything..."
              style={{
                flex: 1,
                padding: '0.6rem',
                borderRadius: '999px',
                border: '1px solid #ccc',
                outline: 'none',
              }}
            />

            <button
              onClick={() => send()}
              style={{
                width: '40px',
                borderRadius: '50%',
                border: 'none',
                background:
                  'linear-gradient(135deg,#4f46e5,#7c3aed)',
                color: '#fff',
                cursor: 'pointer',
              }}
