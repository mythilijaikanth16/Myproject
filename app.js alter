function pick(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

// ── Updated botReply Function ────────────────────────────────────────────────

function botReply(msg, students) {
  const m = msg.toLowerCase();

  // ── Total student count ──────────────────────
  if (
    ['how many', 'total', 'count', 'number of student']
      .some(k => m.includes(k))
  ) {
    const total = students.length;

    const classes = new Set(
      students.map(s => s.student_class).filter(Boolean)
    ).size;

    if (total === 0) {
      return "📊 No students registered yet.";
    }

    return `📊 There are currently **${total} student${
      total !== 1 ? 's' : ''
    }** across **${classes} class${
      classes !== 1 ? 'es' : ''
    }**.`;
  }

  // ── Ascending order ──────────────────────────
  if (
    m.includes('ascending') ||
    m.includes('a-z') ||
    m.includes('sort ascending')
  ) {

    if (students.length === 0) {
      return "❌ No students available.";
    }

    const sorted = [...students].sort((a, b) =>
      a.name.localeCompare(b.name)
    );

    return (
      "📚 Students in ascending order:\n\n" +
      sorted
        .map(
          (s, i) =>
            `${i + 1}. ${s.name} (${s.roll_no})`
        )
        .join('\n')
    );
  }

  // ── Descending order ─────────────────────────
  if (
    m.includes('descending') ||
    m.includes('z-a') ||
    m.includes('sort descending')
  ) {

    if (students.length === 0) {
      return "❌ No students available.";
    }

    const sorted = [...students].sort((a, b) =>
      b.name.localeCompare(a.name)
    );

    return (
      "📚 Students in descending order:\n\n" +
      sorted
        .map(
          (s, i) =>
            `${i + 1}. ${s.name} (${s.roll_no})`
        )
        .join('\n')
    );
  }
  // ── Class wise grouping ───────────────────────
if (
  m.includes('class wise') ||
  m.includes('group by class') ||
  m.includes('sort by class') ||
  m.includes('show classes')
) {

  if (students.length === 0) {
    return "❌ No students available.";
  }

  // Sort by class first, then by name
  const sorted = [...students].sort((a, b) => {

    const classCompare =
      (a.student_class || '').localeCompare(
        b.student_class || ''
      );

    if (classCompare !== 0) {
      return classCompare;
    }

    return (a.name || '').localeCompare(b.name || '');
  });

  const grouped = {};

  sorted.forEach(student => {

    const cls = student.student_class || 'Unknown';

    if (!grouped[cls]) {
      grouped[cls] = [];
    }

    grouped[cls].push(student);
  });

  let response = "🏫 Students grouped by class:\n\n";

  Object.keys(grouped).forEach(cls => {

    response += `📘 ${cls}\n`;

    grouped[cls].forEach((s, i) => {

      response +=
        `   ${i + 1}. ${s.name} (${s.roll_no})\n`;

    });

    response += '\n';
  });

  return response;
}


// ── Find students by class ────────────────────
const classMatch = m.match(
  /(?:class|section)\s*:?\s*([a-z0-9-_]+)/i
);

if (
  m.includes('class') ||
  m.includes('section')
) {

  if (classMatch) {

    const className =
      classMatch[1].toLowerCase();

    const filtered = students.filter(
      s =>
        s.student_class &&
        s.student_class.toLowerCase() === className
    );

    if (filtered.length > 0) {

      return (
        `🏫 Students in class "${className.toUpperCase()}":\n\n` +
        filtered.map((s, i) =>
          `${i + 1}. ${s.name} (${s.roll_no})`
        ).join('\n')
      );
    }

    return `❌ No students found in class "${className}".`;
  }
}


// ── Find specific roll number ─────────────────
const rollMatch = m.match(
  /(?:roll\s*no|roll number|roll)\s*:?\s*([a-z0-9-_]+)/i
);

if (rollMatch) {

  const roll = rollMatch[1].toLowerCase();

  const student = students.find(
    s => s.roll_no?.toLowerCase() === roll
  );

  if (student) {

    return (
      `🎓 Student found:\n\n` +
      `👤 Name: ${student.name}\n` +
      `🆔 Roll No: ${student.roll_no}\n` +
      `🏫 Class: ${student.student_class}`
    );
  }

  return `❌ No student found with roll number "${roll}".`;
}
  // ── Search by student name ───────────────────

  if (
    m.startsWith('find ') ||
    m.startsWith('search ') ||
    m.startsWith('show ')
  ) {

    const query = m
      .replace('find', '')
      .replace('search', '')
      .replace('show', '')
      .trim();

    const found = students.filter(s =>
      s.name.toLowerCase().includes(query)
    );

    if (found.length > 0) {
      return (
        `🔍 Found ${found.length} student(s):\n\n` +
        found.map((s, i) =>
          `${i + 1}. ${s.name} (${s.roll_no}) - ${s.student_class}`
        ).join('\n')
      );
    }
  }

  // ── Existing intents ─────────────────────────

  for (const intent of INTENTS) {

    if (intent.dynamic) continue;

    if (intent.keys.some(k => m.includes(k))) {
      return pick(intent.replies);
    }
  }

  // ── Fallback ─────────────────────────────────

  return pick(FALLBACKS);
}

